# ============================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env.dev and configure your values

# Docker Compose Configuration
COMPOSE_PROJECT_NAME=web_rrhh
NETWORK_NAME=web_rrhh_network

# Database Configuration
POSTGRES_VERSION=16-alpine
POSTGRES_DB=web_rrhh_dev
POSTGRES_USER=web_rrhh_user
POSTGRES_PASSWORD=change_me_secure_password_123
POSTGRES_PORT=5432
POSTGRES_DATA_VOLUME=postgres_data_dev
POSTGRES_HEALTHCHECK_INTERVAL=10s
POSTGRES_HEALTHCHECK_TIMEOUT=5s
POSTGRES_HEALTHCHECK_RETRIES=5

# Backend Configuration
PYTHON_VERSION=3.11-slim
BACKEND_DOCKERFILE=Dockerfile.dev
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_COMMAND=uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload
BACKEND_VOLUME_EXCLUDE=/app/__pycache__

SECRET_KEY=your-super-secret-key-change-this-in-development-min-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENVIRONMENT=development
CORS_ORIGINS=http://localhost,https://localhost,http://localhost:4200
RATE_LIMIT_PER_MINUTE=10

# Frontend Configuration
NODE_VERSION=20-alpine
FRONTEND_DOCKERFILE=Dockerfile.dev
FRONTEND_PORT=4200
NG_SERVE_HOST=0.0.0.0
NG_SERVE_PORT=4200
FRONTEND_COMMAND=npm start
API_URL=http://localhost/api
WS_URL=ws://localhost/ws

# Nginx Configuration
NGINX_VERSION=alpine
HTTP_PORT=80
NGINX_FRONTEND_HOST=frontend
NGINX_FRONTEND_PORT=4200
NGINX_BACKEND_HOST=backend
NGINX_BACKEND_PORT=8000

# Restart Policy
RESTART_POLICY=no

ADMIN_EMAIL=admin@rrhh.com
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=Admin RRHH
ADMIN_ROLE=superadmin

# Upload Size Limits (in MB)
MAX_IMAGE_SIZE_MB=5
MAX_DOCUMENT_SIZE_MB=5
MAX_COMPLAINT_PAYLOAD_MB=10
MAX_NEWS_PAYLOAD_MB=10
DAILY_UPLOAD_QUOTA_MB=10

# --- SMTP Configuration (Per Service) ---

# Auth & System Notifications
SMTP_AUTH_HOST=smtp.gmail.com
SMTP_AUTH_PORT=587
SMTP_AUTH_USER=alertas@inespasa.com
SMTP_AUTH_PASS=password
SMTP_AUTH_TLS=True
EMAIL_AUTH_FROM_NAME="Web RRHH"
EMAIL_AUTH_FROM_ADDRESS=alertas@inespasa.com

# News SMTP Configuration (Optional)
SMTP_NEWS_HOST=smtp.gmail.com
SMTP_NEWS_PORT=587
SMTP_NEWS_USER=alertas@inespasa.com
SMTP_NEWS_PASS=password
SMTP_NEWS_TLS=True
EMAIL_NEWS_FROM_NAME="RRHH Noticias"
EMAIL_NEWS_FROM_ADDRESS=alertas@inespasa.com

# Vacation SMTP Configuration (Optional)
SMTP_VACATION_HOST=smtp.gmail.com
SMTP_VACATION_PORT=587
SMTP_VACATION_USER=alertas@inespasa.com
SMTP_VACATION_PASS=password
SMTP_VACATION_TLS=True
EMAIL_VACATION_FROM_NAME="RRHH Vacaciones"
EMAIL_VACATION_FROM_ADDRESS=alertas@inespasa.com

# Complaint SMTP Configuration (Optional)
SMTP_COMPLAINT_HOST=smtp.gmail.com
SMTP_COMPLAINT_PORT=587
SMTP_COMPLAINT_USER=alertas@inespasa.com
SMTP_COMPLAINT_PASS=password
SMTP_COMPLAINT_TLS=True
EMAIL_COMPLAINT_FROM_NAME="Canal Ético"
EMAIL_COMPLAINT_FROM_ADDRESS=alertas@inespasa.com

# Brute-force Protection
BRUTE_FORCE_MAX_ATTEMPTS=3
BRUTE_FORCE_BLOCK_MINUTES=15
BRUTE_FORCE_REDIRECT_URL="https://www.inespasa.com/"