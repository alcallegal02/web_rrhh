# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env.prod and configure your values
# IMPORTANT: Change all default passwords and secrets!

# Docker Compose Configuration
COMPOSE_PROJECT_NAME=web_rrhh
NETWORK_NAME=web_rrhh_network

# Database Configuration
POSTGRES_VERSION=16-alpine
POSTGRES_DB=web_rrhh
POSTGRES_USER=web_rrhh_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
POSTGRES_PORT=5432
POSTGRES_DATA_VOLUME=postgres_data_prod
POSTGRES_HEALTHCHECK_INTERVAL=10s
POSTGRES_HEALTHCHECK_TIMEOUT=5s
POSTGRES_HEALTHCHECK_RETRIES=5

# Backend Configuration
PYTHON_VERSION=3.11-slim
BACKEND_DOCKERFILE=Dockerfile.prod
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_COMMAND=uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 4
BACKEND_WORKERS=4

SECRET_KEY=CHANGE_THIS_TO_A_VERY_LONG_AND_RANDOM_SECRET_KEY_MIN_64_CHARACTERS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENVIRONMENT=production
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
RATE_LIMIT_PER_MINUTE=10

# Frontend Configuration
NODE_VERSION=20-alpine
NGINX_VERSION=alpine
FRONTEND_DOCKERFILE=Dockerfile.prod
FRONTEND_DIST_PATH=./frontend/dist/web-rrhh
API_URL=https://yourdomain.com/api
WS_URL=wss://yourdomain.com/ws

# Nginx Configuration
HTTP_PORT=80
NGINX_BACKEND_HOST=backend
NGINX_BACKEND_PORT=8000

# Restart Policy
RESTART_POLICY=unless-stopped


# Admin User Configuration
ADMIN_EMAIL=admin@rrhh.com
ADMIN_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
ADMIN_FULL_NAME=Admin RRHH
ADMIN_ROLE=rrhh

