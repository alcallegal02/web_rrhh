# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION (TEMPLATE)
# ============================================
# Copy this file to .env and configure your real production values
# DO NOT COMMIT THE ACTUAL .env FILE TO VERSION CONTROL

# Global Connectivity
PROTOCOL=https
DOMAIN=denuncias.inespasa.com
NGINX_EXTERNAL_PORT=443
HTTPS_PORT=443

# Derived URLs
FRONTEND_URL=${PROTOCOL}://${DOMAIN}
API_URL=/api
WS_URL=/ws

# Service Ports (Internal Docker Mappings)
POSTGRES_EXTERNAL_PORT=5432
REDIS_EXTERNAL_PORT=6379
BACKEND_EXTERNAL_PORT=8000
FRONTEND_EXTERNAL_PORT=8080
MEDIA_EXTERNAL_PORT=8001

# Infrastructure Configuration
NGINX_INTERNAL_PORT=80
POSTGRES_INTERNAL_PORT=5432
REDIS_INTERNAL_PORT=6379
BACKEND_INTERNAL_PORT=8000
FRONTEND_INTERNAL_PORT=4200
FRONTEND_PROD_PORT=8080
MEDIA_INTERNAL_PORT=8000

# Service Hosts
FRONTEND_HOST=frontend
BACKEND_HOST=backend
MEDIA_HOST=media
POSTGRES_HOST=postgres
REDIS_HOST=redis

# Database Configuration
POSTGRES_DB=web_rrhh_prod
POSTGRES_USER=web_rrhh_admin
POSTGRES_PASSWORD=generate_a_very_strong_password_here
DB_AUTO_MIGRATE=true
ADMIN_AUTO_CREATE=true
SEED_TEST_DATA=false

# Backend Security
SECRET_KEY=generate_a_long_random_string_min_64_chars
ENCRYPTION_KEY=generate_a_fernet_key_using_cryptography_library
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=production

# CORS & Security
CORS_ORIGINS=https://denuncias.inespasa.com
ALLOWED_HOSTS=denuncias.inespasa.com,backend,frontend

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Redis Configuration
REDIS_PASSWORD=another_very_strong_password

# Admin Bootstrap
ADMIN_EMAIL=your-admin-email@inespasa.com
ADMIN_PASSWORD=secure_initial_password
ADMIN_FULL_NAME=Admin RRHH
ADMIN_ROLE=superadmin

# Security Configuration
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_BLOCK_MINUTES=30
BRUTE_FORCE_REDIRECT_URL="/"

# SMTP CONFIGURATION (Per Service)
# Use your real SMTP credentials here

# Auth & System Notifications
SMTP_AUTH_HOST=smtp.gmail.com
SMTP_AUTH_PORT=587
SMTP_AUTH_USER=alertas@inespasa.com
SMTP_AUTH_PASS=your_app_password
SMTP_AUTH_TLS=True
EMAIL_AUTH_FROM_NAME="Web RRHH"
EMAIL_AUTH_FROM_ADDRESS=alertas@inespasa.com

# News SMTP
SMTP_NEWS_HOST=smtp.gmail.com
SMTP_NEWS_PORT=587
SMTP_NEWS_USER=alertas@inespasa.com
SMTP_NEWS_PASS=your_app_password
SMTP_NEWS_TLS=True
EMAIL_NEWS_FROM_NAME="RRHH Noticias"
EMAIL_NEWS_FROM_ADDRESS=alertas@inespasa.com

# Vacation SMTP
SMTP_VACATION_HOST=smtp.gmail.com
SMTP_VACATION_PORT=587
SMTP_VACATION_USER=alertas@inespasa.com
SMTP_VACATION_PASS=your_app_password
SMTP_VACATION_TLS=True
EMAIL_VACATION_FROM_NAME="RRHH Vacaciones"
EMAIL_VACATION_FROM_ADDRESS=alertas@inespasa.com

# Complaint SMTP
SMTP_COMPLAINT_HOST=smtp.gmail.com
SMTP_COMPLAINT_PORT=587
SMTP_COMPLAINT_USER=alertas@inespasa.com
SMTP_COMPLAINT_PASS=your_app_password
SMTP_COMPLAINT_TLS=True
EMAIL_COMPLAINT_FROM_NAME="Canal de Denuncias"
EMAIL_COMPLAINT_FROM_ADDRESS=alertas@inespasa.com

# File Upload Limits
MAX_IMAGE_SIZE_MB=10
MAX_DOCUMENT_SIZE_MB=20
MAX_COMPLAINT_PAYLOAD_MB=30
MAX_NEWS_PAYLOAD_MB=20
DAILY_UPLOAD_QUOTA_MB=500
