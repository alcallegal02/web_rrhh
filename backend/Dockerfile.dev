# Development Dockerfile for FastAPI backend
ARG PYTHON_VERSION=3.13-slim
FROM python:${PYTHON_VERSION}

WORKDIR /app


# Install system dependencies (as root)
# Install system dependencies (as root)
RUN apt-get update && apt-get install -y \
    gcc \
    zlib1g-dev \
    libjpeg-dev \
    # Clean up to keep image small
    && rm -rf /var/lib/apt/lists/*

# Create a non-root user
RUN groupadd -r appuser && useradd -r -m -g appuser -u 1000 appuser

# Switch to non-root user
USER appuser
WORKDIR /app

# Configure path for user installs
ENV PATH=/home/appuser/.local/bin:$PATH

# Copy requirements and install Python dependencies
COPY --chown=appuser:appuser requirements.txt .

RUN pip install --upgrade pip && \
    pip install --no-cache-dir --user -r requirements.txt

# Copy application code (though usually bind-mounted in dev)
COPY --chown=appuser:appuser . .

# Expose port
EXPOSE 8000

# Run with reload for development
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]

